# ─────────────────────────────────────────
# Python
# ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.bak
*.orig

# ─────────────────────────────────────────
# Jupyter
# ─────────────────────────────────────────
.ipynb_checkpoints
*.ipynb_checkpoints/

# ─────────────────────────────────────────
# ML model weights (too big for git, don't leak data)
# ─────────────────────────────────────────
weights/
*.pt
*.pth
*.onnx
*.engine
*.trt

# Allow tiny config files inside weights/
!weights/.gitkeep
!weights/*.yaml

# ─────────────────────────────────────────
# Datasets and media
# ─────────────────────────────────────────
data/
datasets/
*.mp4
*.avi
*.mov
*.mkv
*.jpg
*.jpeg
*.png
*.tar.gz
*.zip

# Allow images used for documentation
!docs/**/*.png
!docs/**/*.jpg
!README_assets/**

# ─────────────────────────────────────────
# Outputs and logs
# ─────────────────────────────────────────
output/
outputs/
runs/
logs/
*.log
*.csv
test_output*

# ─────────────────────────────────────────
# Frontend (if ever committed here by accident)
# ─────────────────────────────────────────
node_modules/
.expo/
*.tsbuildinfo

# ─────────────────────────────────────────
# Secrets — NEVER commit these
# ─────────────────────────────────────────
.env
*.key
*.pem
secrets.json
# TensorRT engine files (Jetson-specific, GPU-tied binaries)
*.engine
*.onnx
